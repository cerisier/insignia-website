---
const releases = [
  { id: "INS007", title: "Luna EP", artist: "Glenn Morrison & Night Waves", cover: "/releases/INS007.jpg" },
  { id: "INS006", title: "Drifting", artist: "DJ Cøsmic Dream", cover: "/releases/INS006.jpg" },
  { id: "INS005", title: "Turtle Beach", artist: "DJ Cøsmic Dream", cover: "/releases/INS005.jpg" },
  { id: "INS004", title: "Friday", artist: "DJ Cøsmic Dream", cover: "/releases/INS004.jpg" },
  { id: "INS003", title: "Love.exe", artist: "DJ Cøsmic Dream", cover: "/releases/INS003.jpg" },
  { id: "INS002", title: "Dolphin Dreams", artist: "DJ Cøsmic Dream", cover: "/releases/INS002.jpg" },
  { id: "INS001", title: "Faster", artist: "DJ Cøsmic Dream", cover: "/releases/INS001.jpg" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Insignia is an independent electronic label transmitting releases, mixes, and signals from the edge."
    />
    <title>Insignia</title>
  </head>
  <body>
    <header class="topbar" aria-label="Insignia">
      <a class="topbar-logo" href="/" aria-label="Insignia home">
        <img src="/insignia-icon.png" alt="Insignia" />
      </a>
      <nav class="topbar-nav" aria-label="Main navigation">
        <a href="#about">About</a>
        <a href="#releases">Releases</a>
        <a href="#artists">Artists</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main class="site-shell">
      <section class="release-section" aria-labelledby="releases-title" id="releases">
        <div class="section-rule">
          <h1 id="releases-title">Releases</h1>
          <span>007</span>
        </div>

        <div class="release-grid">
          {
            releases.map((release) => (
              <article class="release-card">
                <a href="#subscribe" aria-label={`${release.artist} - ${release.title}`}>
                  <img class="release-cover" src={release.cover} alt={`${release.artist} - ${release.title}`} />
                  <span class="release-copy">
                    <span>{release.id}</span>
                    <strong>{release.title}</strong>
                    <em>{release.artist}</em>
                  </span>
                </a>
              </article>
            ))
          }
        </div>
      </section>

      <section class="subscribe-panel" id="subscribe" aria-labelledby="subscribe-title">
        <div class="panel-label">// Subscribe</div>
        <div>
          <h2 id="subscribe-title">Stay in<br />the signal.</h2>
          <p>New releases, mixes, and transmissions direct to your inbox. No spam. Unsubscribe anytime.</p>
        </div>
        <form name="subscribe" method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value="subscribe" />
          <label>
            <span>Email address</span>
            <input type="email" name="email" placeholder="Your e-mail address" required />
          </label>
          <button type="submit">Subscribe</button>
        </form>
      </section>

      <footer class="site-footer">
        <p>© 2025 Insignia. All rights reserved.</p>
        <nav aria-label="Social links">
          <a href="https://bandcamp.com" rel="noreferrer">Bandcamp</a>
          <a href="https://soundcloud.com" rel="noreferrer">Soundcloud</a>
          <a href="https://instagram.com" rel="noreferrer">Instagram</a>
        </nav>
      </footer>
    </main>
  </body>

</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f8f8f5;
    --fg: #111110;
    --muted: #9a9a90;
    --line: #e4e4de;
    --panel: #eeeee9;
    --edge: #d8d8d0;
    --font-body:
      "Arial Narrow", "Helvetica Neue Condensed", "Roboto Condensed", "Avenir Next Condensed",
      system-ui, sans-serif;
    --font-display:
      "Eurostile Extended", "Microgramma", "Arial Rounded MT Bold", "Helvetica Neue", system-ui,
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    min-width: 320px;
    margin: 0;
    color: var(--fg);
    background:
      radial-gradient(circle at 50% 0%, rgba(0, 0, 0, 0.03), transparent 28rem),
      linear-gradient(var(--bg), var(--bg));
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.35;
    text-transform: uppercase;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-shell {
    width: min(100% - 2rem, 58rem);
    min-height: 100vh;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem) 0 2.75rem;
  }

  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(1rem, 4vw, 3rem);
    height: 3.5rem;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
  }

  .topbar-logo img {
    display: block;
    height: 1.6rem;
    width: auto;
    filter: brightness(0);
  }

  .topbar-nav {
    display: flex;
    align-items: center;
    gap: clamp(1.2rem, 3vw, 2.2rem);
    font-size: 0.68rem;
    font-weight: 800;
  }

  .topbar-nav a {
    color: var(--muted);
    transition: color 120ms ease;
  }

  .topbar-nav a:hover {
    color: var(--fg);
  }

  .release-loop {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .section-rule,
  .release-copy,
  .panel-label,
  .site-footer,
  input,
  button {
    font-size: 0.68rem;
    font-weight: 800;
  }

  .section-rule {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    color: var(--fg);
  }

  .section-rule::before,
  .section-rule::after {
    display: block;
    height: 1px;
    background: var(--line);
    content: "";
  }

  .section-rule::before {
    display: none;
  }

  .section-rule h1 {
    margin: 0;
    font: inherit;
  }

  .section-rule span {
    color: var(--muted);
  }

  .release-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .release-card {
    position: relative;
    aspect-ratio: 1;
    min-width: 0;
    background: #111;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }

  .release-card a {
    position: absolute;
    inset: 0;
    display: block;
  }

  .release-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }

  .release-card:hover .release-cover {
    transform: scale(1.06);
  }

  .release-loop {
    stroke-width: 21;
  }

  .release-copy {
    position: absolute;
    left: 1rem;
    bottom: 0.85rem;
    z-index: 5;
    display: grid;
    gap: 0.1rem;
    color: #fff;
    line-height: 1;
    opacity: 0;
    transition: opacity 160ms ease;
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
  }

  .release-card:hover .release-copy,
  .release-card:focus-within .release-copy {
    opacity: 1;
  }

  .release-copy strong,
  .release-copy em {
    display: block;
    font-style: normal;
  }

  .release-copy span {
    color: rgba(255, 255, 255, 0.6);
  }

  .subscribe-panel {
    position: relative;
    display: grid;
    grid-template-columns: 1fr minmax(16rem, 18rem);
    gap: clamp(1.5rem, 8vw, 8rem);
    margin-top: clamp(3rem, 7vw, 4.6rem);
    padding: clamp(2rem, 4vw, 2.7rem) clamp(1.4rem, 4vw, 2.5rem);
    border: 1px solid var(--edge);
    background: var(--panel);
  }

  .panel-label {
    position: absolute;
    top: -0.55rem;
    left: 1.6rem;
    padding: 0 0.55rem;
    color: var(--muted);
    background: var(--bg);
  }

  .subscribe-panel h2 {
    max-width: 14rem;
    margin: 0 0 1rem;
    font-size: clamp(1.1rem, 2.4vw, 1.45rem);
    line-height: 1.18;
  }

  .subscribe-panel p {
    max-width: 24rem;
    margin: 0;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: none;
  }

  form {
    align-self: center;
    display: grid;
    gap: 0.7rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
  }

  label span {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  input,
  button {
    width: 100%;
    min-height: 2.1rem;
    border-radius: 0;
    font-family: var(--font-body);
    text-transform: uppercase;
  }

  input {
    border: 1px solid var(--edge);
    padding: 0 0.85rem;
    color: var(--fg);
    background: var(--bg);
  }

  input::placeholder {
    color: var(--muted);
    opacity: 1;
  }

  button {
    border: 1px solid var(--fg);
    color: var(--bg);
    background: var(--fg);
    cursor: pointer;
  }

  button:hover,
  button:focus-visible {
    color: var(--fg);
    background: var(--bg);
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: clamp(3rem, 8vw, 4.8rem);
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
  }

  .site-footer p {
    margin: 0;
  }

  .site-footer nav {
    display: flex;
    gap: 1.4rem;
  }

  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: var(--fg);
  }

  @media (max-width: 760px) {
    .site-shell {
      width: min(100% - 1.25rem, 38rem);
      padding-top: 2rem;
    }

    .release-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .subscribe-panel {
      grid-template-columns: 1fr;
      gap: 1.6rem;
    }

    .site-footer {
      display: grid;
    }

    .site-footer nav {
      flex-wrap: wrap;
      gap: 0.8rem 1.2rem;
    }
  }

  @media (max-width: 430px) {
    .release-grid {
      grid-template-columns: 1fr;
    }

    .release-card {
      max-height: calc(100vw - 1.25rem);
    }
  }
</style>
